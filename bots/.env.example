# Copy to bots/.env and fill in. NEVER commit bots/.env.

# TxLINE data token (same one the apps use). Copy from derisk/.env TXLINE_API_TOKEN.
TXLINE_API_TOKEN=

# One Telegram bot token per platform. Create each with @BotFather (/newbot) and paste here.
WHISTL_BOT_TOKEN=
PULSE_BOT_TOKEN=
TRADER_BOT_TOKEN=

# OPTIONAL: a fixed channel/group to also broadcast to (numeric chat id, e.g. -1001234567890).
# Add the bot to the channel as an admin. Leave blank to broadcast only to users who DM /start.
WHISTL_CHAT_ID=
PULSE_CHAT_ID=
TRADER_CHAT_ID=
