# ─── WHISTL (apps/whistl) — Vercel Environment Variables ──────────────────────
# Copy the real values from apps/whistl/.env.local into your Vercel project
# (Settings → Environment Variables, apply to Production + Preview).
# Everything marked [shared] must be IDENTICAL across all three apps — that is the
# shared backend + smart contract (same ORA wallet, TxLINE token, Supabase, program).

# TxLINE data feed [shared]
TXLINE_API_TOKEN=

# ACE Data Cloud — gpt-4o-mini [shared]
ACE_API_KEY=

# ORA + mint authority wallets — Solana devnet, base58 secret keys [shared]
ORA_SECRET_BASE58=
MINT_AUTHORITY_SECRET_BASE58=
NEXT_PUBLIC_ORA_PUBKEY=

# Solana [shared]
NEXT_PUBLIC_SOLANA_RPC=
NEXT_PUBLIC_SOLANA_CLUSTER=devnet
NEXT_PUBLIC_WHISTL_PROGRAM_ID=
NEXT_PUBLIC_TXLINE_PROGRAM_ID=
NEXT_PUBLIC_TEST_USDC_MINT=

# Privy auth [shared]
NEXT_PUBLIC_PRIVY_APP_ID=
PRIVY_APP_SECRET=

# Supabase [shared]
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Optional — leave BLANK on Vercel. Internal API calls auto-use Vercel's VERCEL_URL.
# Only set this if you want to pin a specific public URL.
NEXT_PUBLIC_BASE_URL=
