# Copy to .env and fill in. NEVER commit .env.
# A devnet keypair is needed to sign the on-chain `subscribe` tx (free World Cup tier).
# Generate one with the helper in 02-subscribe-activate.mjs, or paste an existing
# base58 secret key. Devnet SOL is free via airdrop.
DEVNET_KEYPAIR_BASE58=

# Optional: a custom devnet RPC (Helius free tier recommended). Defaults to public devnet.
DEVNET_RPC_URL=https://api.devnet.solana.com

# Filled in automatically once you activate a subscription (02 writes it here).
TXLINE_API_TOKEN=
