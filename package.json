{
  "name": "whistl-workspace",
  "private": true,
  "packageManager": "npm@11.16.0",
  "workspaces": [
    "apps/*",
    "packages/*",
    "agent",
    "whistl/app"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build --filter=./apps/*",
    "lint": "turbo run lint"
  },
  "devDependencies": {
    "turbo": "^2.0.0"
  }
}
